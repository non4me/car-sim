  },
  "options": [
    {
      "text": {
        "cs": "Rychle se zařadím před něj",
        "en": "Quickly pull in front of it",
        "ru": "Быстро встрою перед ним"
      },
      "correct": false,
      "rule": "prednost_zprava"
